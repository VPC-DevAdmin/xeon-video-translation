# --- Models (CPU-friendly defaults) -------------------------------------------
# Whisper model size: tiny | base | small | medium | large-v3
# `base` is the sweet spot on Xeon CPU; bump to `small` for better quality.
WHISPER_MODEL=base
# faster-whisper compute type: int8 | int8_float32 | float32
WHISPER_COMPUTE_TYPE=int8

# Translation backend: nllb (default, CPU friendly) | ollama (uses local Ollama)
TRANSLATE_BACKEND=nllb
NLLB_MODEL=facebook/nllb-200-distilled-600M
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# --- Limits -------------------------------------------------------------------
MAX_VIDEO_DURATION_SECONDS=60
MAX_VIDEO_SIZE_MB=100
MAX_CONCURRENT_JOBS=1

# --- Paths --------------------------------------------------------------------
MODEL_CACHE_DIR=./models
JOB_ARTIFACTS_DIR=./jobs

# --- Server -------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
# Host-side port for the backend. Inside the container uvicorn always listens
# on 8000; this only changes the `host:container` port mapping. 8000 is often
# taken by other local apps, so default to 8088.
BACKEND_PORT=8088
# Host-side port for the Next.js frontend. Inside the container Next.js always
# listens on 3000; this only changes the `host:container` port mapping.
FRONTEND_PORT=3030
CORS_ORIGINS=http://localhost:3030

# --- Lipsync (Stage 5) --------------------------------------------------------
# Backend: none | wav2lip | musetalk | latentsync
# - none: skip lipsync. Mux dubs new audio over the original video.
# - wav2lip: ~30-60s per 3s clip on a 16-core Xeon. CC-BY-NC 4.0 weights.
# - musetalk / latentsync: currently stubbed. See docs/lipsync.md.
LIPSYNC_BACKEND=none
WAV2LIP_CHECKPOINT_URL=https://github.com/justinjohn0306/Wav2Lip/releases/download/models/wav2lip_gan.pth

# MuseTalk runs in its own Compose service (lipsync-musetalk). Host port is
# configurable so it doesn't clash with the backend/frontend on multi-project
# machines. Backend reaches the service via Docker DNS, not this port.
MUSETALK_PORT=8089

# LatentSync also runs in its own Compose service. Host port default 8090.
LATENTSYNC_PORT=8090

# --- LatentSync per-request defaults ------------------------------------------
# Seed the default per-request knobs. Callers can still override per-request.
#
# Denoising steps. LatentSync recommends 20; below 10 quality drops fast.
# LATENTSYNC_STEPS=20
#
# Classifier-free guidance scale. At 1.0 CFG is disabled (CFG kicks in when
# guidance_scale > 1.0). Default 1.5 gives a mild audio-conditioning push;
# 2.0–3.0 pushes harder at the cost of some identity drift. Raise this if
# the output mouth looks translucent or mushy.
# LATENTSYNC_GUIDANCE=1.5

# --- LatentSync performance knobs (opt-out, both default-on) ------------------
# IPEX compute dtype. bf16 enables torch.autocast around the UNet forward —
# 2–4x faster than fp32 on AMX-capable Xeon (Sapphire Rapids+). Set to fp32
# if you're chasing an output-quality issue and want to rule out bf16 drift.
# LATENTSYNC_IPEX_DTYPE=bf16

# DeepCache — caches early denoising-step tensors and reuses them later.
# ~1.3x on top of IPEX. Set to 0 to disable if you suspect it's producing
# artifacts (it usually isn't at cache_interval=3, the upstream default).
# LATENTSYNC_ENABLE_DEEPCACHE=1

# Dry-run mode — collapses num_inference_steps to 1 for fast wiring smoke
# tests. Output is unusable (rainbow noise in the mask region) but the
# whole pipeline runs end-to-end in minutes instead of hours. Use this to
# verify an environment change before committing to a full run.
# LATENTSYNC_DRY_RUN=0

# Debug-dump mode — save intermediate images from face detection, affine
# warp, and the restore_img step into LATENTSYNC_DEBUG_DIR
# (default /jobs/latentsync_debug/). Use this to diagnose quality
# problems: if the output looks wrong, enable and check which stage
# first produces something that looks wrong. Rate-limited to
# LATENTSYNC_DEBUG_FRAME_LIMIT frames per stage (default 3).
# LATENTSYNC_DEBUG_DUMP=0
# LATENTSYNC_DEBUG_FRAME_LIMIT=3

# Temporal smoothing window for per-frame affine matrices + bboxes.
# Reduces "face breathing" jitter where unmasked regions shift 1-2
# pixels between adjacent frames due to landmark detection noise.
# Centered moving average. Default 5; 1 disables. Larger values smooth
# more aggressively but introduce lag on real head motion (a 9-frame
# window with a quick head turn will visibly trail by ~4 frames).
# LATENTSYNC_AFFINE_SMOOTH_WINDOW=5

# --- Feature flags ------------------------------------------------------------
# Watermark MUST remain true unless you are doing internal testing. See docs/ethics.md.
ENABLE_WATERMARK=true
ENABLE_C2PA=false
WATERMARK_TEXT=AI-translated

# --- CPU tuning ---------------------------------------------------------------
# Number of CPU threads for inference. Leave these UNSET (commented out) to
# let each library pick its own default — libgomp rejects an empty string and
# prints a scary-looking warning. Uncomment and set to your physical core
# count if you want to pin it.
# OMP_NUM_THREADS=8
# MKL_NUM_THREADS=8

# MuseTalk service IPEX compute dtype. fp32 is safe; bf16 is opt-in and
# ~1.5-2x faster on Sapphire Rapids / Emerald Rapids via AMX. Possible
# subtle quality drift at bf16 — try it and compare outputs.
# MUSETALK_IPEX_DTYPE=fp32

# MuseTalk blend mode. Controls what part of the predicted face is actually
# composited back into the frame.
#   raw    — full lower face (original v1.0 behavior; replaces everything)
#   jaw    — chin + cheeks + mouth (default; chin tracks lips = correct anatomy)
#   mouth  — lips + teeth only (tightest; preserves stubble but causes
#            "sticker" effect because chin stays frozen while lips move)
#   neck   — extends into the neck (rare; usually not what you want)
# MUSETALK_BLEND_MODE=jaw

# Gaussian feather kernel as a fraction of the face-crop width. Larger =
# softer seam (but ghosts small masks). The service caps the absolute
# kernel at 31 px, so values above ~0.08 have no extra effect on big
# crops — the ratio is mostly useful for tightening the feather below
# the default.
# MUSETALK_BLEND_FEATHER=0.04

# Face restoration — runs CodeFormer on each output frame to recover
# high-frequency skin detail (pores, stubble) that the MuseTalk VAE
# smoothed out. Adds ~3-8s per frame on CPU. Set to "none" to skip.
# MUSETALK_FACE_RESTORE=codeformer

# Identity-vs-quality slider for CodeFormer. 0.0 = maximum visual fidelity
# (can morph identity), 1.0 = maximum identity preservation (less detail
# recovery). 0.7 is the commonly recommended balance.
# MUSETALK_FACE_RESTORE_FIDELITY=0.7

# How strongly the restored face blends into the MuseTalk output. Lower
# values preserve more of MuseTalk's original output (useful if CodeFormer
# drifts the identity too far). 0.6 is a safe default.
# MUSETALK_FACE_RESTORE_BLEND=0.6

# --- HuggingFace Hub ----------------------------------------------------------
# Optional token for higher download rate limits (HF prompts for this on first
# download). Create one at https://huggingface.co/settings/tokens — read-only
# is enough. Leave commented out to keep using anonymous access.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Frontend -----------------------------------------------------------------
# Used by `npm run dev` (outside Docker). In Docker, docker-compose.yml derives
# this from BACKEND_PORT automatically — keep these in sync if you override.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088

# --- CLI workflow (used by Makefile + scripts) --------------------------------
# These let you run `make run` or `make fetch` without repeating CLI flags.
# Override per-invocation with `make run FIXTURE=... TARGET=ja`.
#
# FIXTURE   — path to the source video. Put clips under artifacts/inputs/.
# TARGET    — target language (BCP-47: es, fr, de, ja, zh, hi, pt, it, ko, ...)
# LIPSYNC   — none | wav2lip | musetalk | latentsync
# OUT_ROOT  — where fetch.sh writes downloaded job artifacts.
# FIXTURE=artifacts/inputs/IMG_7228.MOV
# TARGET=es
# LIPSYNC=none
# OUT_ROOT=./artifacts/jobs
