# --- Models (CPU-friendly defaults) -------------------------------------------
# Whisper model size: tiny | base | small | medium | large-v3
# `base` is the sweet spot on Xeon CPU; bump to `small` for better quality.
WHISPER_MODEL=base
# faster-whisper compute type: int8 | int8_float32 | float32
WHISPER_COMPUTE_TYPE=int8

# Translation backend: nllb (default, CPU friendly) | ollama (uses local Ollama)
TRANSLATE_BACKEND=nllb
NLLB_MODEL=facebook/nllb-200-distilled-600M
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# --- Limits -------------------------------------------------------------------
MAX_VIDEO_DURATION_SECONDS=60
MAX_VIDEO_SIZE_MB=100
MAX_CONCURRENT_JOBS=1

# --- Paths --------------------------------------------------------------------
MODEL_CACHE_DIR=./models
JOB_ARTIFACTS_DIR=./jobs

# --- Server -------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
# Host-side port for the backend. Inside the container uvicorn always listens
# on 8000; this only changes the `host:container` port mapping. 8000 is often
# taken by other local apps, so default to 8088.
BACKEND_PORT=8088
# Host-side port for the Next.js frontend. Inside the container Next.js always
# listens on 3000; this only changes the `host:container` port mapping.
FRONTEND_PORT=3030
CORS_ORIGINS=http://localhost:3030

# --- Lipsync (Stage 5) --------------------------------------------------------
# Backend: none | wav2lip | musetalk | latentsync
# - none: skip lipsync. Mux dubs new audio over the original video.
# - wav2lip: ~30-60s per 3s clip on a 16-core Xeon. CC-BY-NC 4.0 weights.
# - musetalk / latentsync: currently stubbed. See docs/lipsync.md.
LIPSYNC_BACKEND=none
WAV2LIP_CHECKPOINT_URL=https://github.com/justinjohn0306/Wav2Lip/releases/download/models/wav2lip_gan.pth

# MuseTalk runs in its own Compose service (lipsync-musetalk). Host port is
# configurable so it doesn't clash with the backend/frontend on multi-project
# machines. Backend reaches the service via Docker DNS, not this port.
MUSETALK_PORT=8089

# --- Feature flags ------------------------------------------------------------
# Watermark MUST remain true unless you are doing internal testing. See docs/ethics.md.
ENABLE_WATERMARK=true
ENABLE_C2PA=false
WATERMARK_TEXT=AI-translated

# --- CPU tuning ---------------------------------------------------------------
# Number of CPU threads for inference. Leave these UNSET (commented out) to
# let each library pick its own default — libgomp rejects an empty string and
# prints a scary-looking warning. Uncomment and set to your physical core
# count if you want to pin it.
# OMP_NUM_THREADS=8
# MKL_NUM_THREADS=8

# --- HuggingFace Hub ----------------------------------------------------------
# Optional token for higher download rate limits (HF prompts for this on first
# download). Create one at https://huggingface.co/settings/tokens — read-only
# is enough. Leave commented out to keep using anonymous access.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Frontend -----------------------------------------------------------------
# Used by `npm run dev` (outside Docker). In Docker, docker-compose.yml derives
# this from BACKEND_PORT automatically — keep these in sync if you override.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088

# --- CLI workflow (used by Makefile + scripts) --------------------------------
# These let you run `make run` or `make fetch` without repeating CLI flags.
# Override per-invocation with `make run FIXTURE=... TARGET=ja`.
#
# FIXTURE   — path to the source video. Put clips under artifacts/inputs/.
# TARGET    — target language (BCP-47: es, fr, de, ja, zh, hi, pt, it, ko, ...)
# LIPSYNC   — none | wav2lip | musetalk | latentsync
# OUT_ROOT  — where fetch.sh writes downloaded job artifacts.
# FIXTURE=artifacts/inputs/IMG_7228.MOV
# TARGET=es
# LIPSYNC=none
# OUT_ROOT=./artifacts/jobs
